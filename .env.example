# ──────────────────────────────────────────────
# options-discord-engine — environment config
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# ── Discord ────────────────────────────────────
# Webhook URL from your Discord server settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── JarvisFlow ─────────────────────────────────
# API key from jarvisflow.io
JARVIS_API_KEY=sk-your-jarvis-key-here

# ── Scoring & Filtering ────────────────────────
# Alerts below this score are suppressed (0–100)
MIN_ALERT_SCORE=70

# How long (minutes) before the same alert can fire again
DEDUPE_WINDOW_MINUTES=30

# ── Auto-polling ───────────────────────────────
# Enable the background scheduled poller
AUTO_POLL_ENABLED=true

# How often to poll JarvisFlow (seconds)
POLL_INTERVAL_SECONDS=60

# Comma-separated tickers to auto-poll
AUTO_POLL_TICKERS=SPY,QQQ,NVDA

# ── Database ───────────────────────────────────
# Path to the SQLite database file
DB_PATH=alerts.db

# ── MCP Server (Phase 1) ───────────────────────
# Port for SSE transport (used when running: python mcp_server.py --sse)
MCP_PORT=8001
